{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "typstr",
  "version": "0.1.0",
  "identifier": "dev.typstr.app",
  "build": {
    "beforeDevCommand": "python3 ../tools/dev_server.py 4173",
    "beforeBuildCommand": "",
